{
  "name": "roxy-portfolio",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "generate-manifest": "node scripts/generate-postcard-manifest.js",
    "generate-i18n": "node scripts/generate-i18n.js",
